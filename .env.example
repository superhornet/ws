# Server
SERVER_PORT=3000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_DATABASE=your_database
POSTGRES_PORT=5432

# Optional (have defaults):
# Postgres pool tuning
POSTGRES_MAX=10                    # max pool connections (default: 10)
POSTGRES_IDLETIMEOUT=30000         # idle timeout in ms (default: 30000)
POSTGRES_CONNECTIONTIMEOUT=2000    # connection timeout in ms (default: 2000)

# Cybrid API
CYBRID_CLIENT_ID=your_cybrid_client_id
CYBRID_CLIENT_SECRET=your_cybrid_client_secret

# Cybrid endpoints (default to sandbox)
CYBRID_API_BASE=https://bank.sandbox.cybrid.app
CYBRID_AUTH_URL=https://id.sandbox.cybrid.app/oauth/token
